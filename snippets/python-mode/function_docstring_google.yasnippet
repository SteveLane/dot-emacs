# -*- mode: snippet -*-
# name: function_docstring_google
# key: fdg
# group: definitions
# Use minimum indentation, because Emacs 25+ doesn't dedent docstrings.
# --
def ${1:Function Name}(${2:Arguments}) -> ${3:ReturnType}:
    \"\"\"${4:Short Description}

    Args:
        ${2:$(sprazza/yas-args-to-google)}

    Returns:
        ${5:Return type}
    \"\"\"
 $0